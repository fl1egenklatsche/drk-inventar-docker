{$HOSTNAME} {
    # Let's Encrypt automatisch via ACME
    # Zertifikate werden in /data/caddy gespeichert
    
    # Root directory
    root * /var/www/html
    
    # Index files
    file_server
    
    # Try files in order
    try_files {path} {path}/ /index.php?{query}
    
    # PHP-FPM Backend
    php_fastcgi app:9000 {
        index index.php
    }
    
    # Gzip compression
    encode gzip
    
    # Security Headers
    header {
        X-Frame-Options "SAMEORIGIN"
        X-Content-Type-Options "nosniff"
        X-XSS-Protection "1; mode=block"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
    }
    
    # Logging
    log {
        output stdout
        format console
    }
    
    # Error Pages
    handle_errors {
        respond "{http.error.status_code} {http.error.status_text}"
    }
}
